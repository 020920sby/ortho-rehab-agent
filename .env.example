# ===========================================
# 骨科康复智能体 - 环境配置
# ===========================================
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# LLM配置 (百川智能 API — OpenAI 兼容)
# 也支持任意 OpenAI 兼容接口（如本地 vLLM、其他国产模型）
LLM_BASE_URL=https://api.baichuan-ai.com/v1
LLM_MODEL=Baichuan4
LLM_API_KEY=your_api_key_here

# 向量数据库
CHROMA_PERSIST_DIR=./chroma_db

# LangGraph 状态持久化（checkpoint，用于人机协同中断恢复）
CHECKPOINT_DB_PATH=./data/checkpoints.db

# Embedding模型 (百川Text-Embedding API)
EMBEDDING_MODEL=Baichuan-Text-Embedding

# 知识库路径
KNOWLEDGE_GUIDELINES_DIR=./knowledge/guidelines
KNOWLEDGE_SCALES_DIR=./knowledge/scales

# 可观测性 (Langfuse — 可选，用于 token 用量追踪和 prompt 版本管理)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# 安全配置 — 触发紧急预警的关键词（逗号分隔）
EMERGENCY_KEYWORDS=胸痛,呼吸困难,咯血,意识模糊,剧烈疼痛,伤口大量出血,高热不退

# API服务配置
API_HOST=0.0.0.0
API_PORT=8001

# Streamlit配置（备选前端，主前端为 React）
STREAMLIT_PORT=8501

# 日志级别
LOG_LEVEL=INFO
